<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="conference.controller.LoginController"
           styleClass="login-root">
    
    <VBox fx:id="loginBox" alignment="CENTER" spacing="0"
          maxWidth="420" maxHeight="580"
          styleClass="login-card">
        
        <!-- En-tête -->
        <VBox alignment="CENTER" spacing="8" styleClass="login-header">
            <Label text="🏢" style="-fx-font-size: 48px;"/>
            <Label text="Système de Réservation" styleClass="login-title"/>
            <Label text="Salle de Conférence" styleClass="login-subtitle"/>
        </VBox>
        
        <!-- Formulaire -->
        <VBox spacing="16" styleClass="login-form">
            <VBox spacing="6">
                <Label text="Adresse Email" styleClass="form-label"/>
                <TextField fx:id="tfEmail" promptText="votre@email.com" styleClass="form-input"/>
            </VBox>
            
            <VBox spacing="6">
                <Label text="Mot de passe" styleClass="form-label"/>
                <PasswordField fx:id="pfPassword" promptText="••••••••" styleClass="form-input"/>
            </VBox>
            
            <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>
            
            <Button fx:id="btnConnexion" text="Se Connecter" maxWidth="Infinity"
                    onAction="#handleConnexion" styleClass="btn-primary"/>
            
            <ProgressIndicator fx:id="progressIndicator" maxWidth="40" maxHeight="40"
                               VBox.vgrow="NEVER" style="-fx-progress-color: #2196F3;"/>
        </VBox>
        
        <!-- Pied de page -->
        <VBox alignment="CENTER" spacing="4" styleClass="login-footer">
            <Label text="© 2026 Système de Gestion de Réservation" styleClass="footer-text"/>
            <Label text="Version 1.0" styleClass="footer-text"/>
        </VBox>
        
    </VBox>
</StackPane>
