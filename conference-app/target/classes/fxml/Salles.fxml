<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<SplitPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="conference.controller.SallesController"
           orientation="HORIZONTAL" dividerPositions="0.65"
           styleClass="page-container-split">

    <VBox spacing="12" styleClass="page-container">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Gestion des Salles" styleClass="page-title"/>
                <Label text="Gérez les salles de conférence disponibles" styleClass="page-subtitle"/>
            </VBox>
            <Button text="+ Nouvelle Salle" onAction="#handleNouvelleSalle" styleClass="btn-primary"/>
            <Button text="🔄 Actualiser" onAction="#handleRafraichir" styleClass="btn-secondary"/>
        </HBox>
        
        <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="tfRecherche" promptText="🔍 Rechercher une salle..." prefWidth="280"/>
        </HBox>
        
        <TableView fx:id="tableSalles" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNom" text="Nom de la salle" prefWidth="180"/>
                <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="80"/>
                <TableColumn fx:id="colLocalisation" text="Localisation" prefWidth="150"/>
                <TableColumn fx:id="colEtage" text="Étage" prefWidth="100"/>
                <TableColumn fx:id="colDisposition" text="Disposition" prefWidth="110"/>
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="90"/>
            </columns>
            <placeholder><Label text="Aucune salle trouvée"/></placeholder>
        </TableView>
    </VBox>
    
    <VBox fx:id="formPane" spacing="12" styleClass="page-container form-panel" minWidth="320">
        <Label fx:id="lblFormTitre" text="Nouvelle Salle" styleClass="form-section-title"/>
        
        <VBox spacing="4"><Label text="Nom *" styleClass="form-label"/>
            <TextField fx:id="tfNom" promptText="Nom de la salle"/></VBox>
        
        <VBox spacing="4"><Label text="Description" styleClass="form-label"/>
            <TextArea fx:id="taDescription" prefRowCount="2" promptText="Description..."/></VBox>
        
        <HBox spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Capacité *" styleClass="form-label"/>
                <TextField fx:id="tfCapacite" promptText="Ex: 50"/></VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Superficie (m²)" styleClass="form-label"/>
                <TextField fx:id="tfSuperficie" promptText="Ex: 80"/></VBox>
        </HBox>
        
        <VBox spacing="4"><Label text="Localisation" styleClass="form-label"/>
            <TextField fx:id="tfLocalisation" promptText="Bâtiment A, Bâtiment B..."/></VBox>
        
        <VBox spacing="4"><Label text="Étage" styleClass="form-label"/>
            <TextField fx:id="tfEtage" promptText="RDC, 1er étage..."/></VBox>
        
        <VBox spacing="4"><Label text="Disposition par défaut" styleClass="form-label"/>
            <ComboBox fx:id="cbDisposition" maxWidth="Infinity"/></VBox>
        
        <CheckBox fx:id="chkActif" text="Salle active" selected="true"/>
        
        <Region VBox.vgrow="ALWAYS"/>
        
        <HBox spacing="10">
            <Button text="💾 Sauvegarder" onAction="#handleSauvegarder" styleClass="btn-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Annuler" onAction="#handleAnnulerForm" styleClass="btn-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </VBox>
    
</SplitPane>
